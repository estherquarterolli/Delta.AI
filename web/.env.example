# Copie para `web/.env.local` e preencha com valores reais.
# NUNCA commite `.env.local`. Só variáveis com prefixo NEXT_PUBLIC_ são
# expostas ao browser — devem ser sempre valores públicos por natureza
# (ex.: anon key do Supabase respeita RLS, não é segredo de servidor).
# Espelha a seção "Frontend" de `.env.example` (raiz do projeto).

# URL e chave anônima (pública) do projeto Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL do backend FastAPI (local: http://localhost:8000).
NEXT_PUBLIC_API_URL=http://localhost:8000
