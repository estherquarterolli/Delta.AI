# ============================================================
# Delta.AI — Variáveis de ambiente (exemplo)
# ============================================================
# Copie este arquivo para `.env` (raiz, usado pelo backend/docker-compose)
# e/ou `web/.env.local` (frontend Next.js) e preencha com valores reais.
#
# NUNCA commite o `.env` real — só este `.env.example` é versionado.
# Em produção, segredos vivem em Fly secrets (backend) e Vercel env
# (frontend), nunca em código ou arquivos .yml.

# ------------------------------------------------------------
# Supabase (DB + Storage + Auth) — https://supabase.com
# ------------------------------------------------------------
# URL do projeto Supabase (mesma para backend e frontend)
SUPABASE_URL=

# Chave anônima (public) do Supabase — respeita RLS, segura pro client
SUPABASE_ANON_KEY=

# Chave service_role — bypassa RLS. Uso restrito a cron jobs
# explicitamente justificados em ADR (docs/adr/). NUNCA usar em
# request handler exposto a usuário (regra do CLAUDE.md).
SUPABASE_SERVICE_ROLE_KEY=

# Connection string direta do Postgres (migrations via CLI, tooling
# local). Formato: postgresql://postgres:[senha]@[host]:5432/postgres
DATABASE_URL=

# ------------------------------------------------------------
# Frontend (Next.js) — variáveis públicas expostas ao browser.
# Prefixo NEXT_PUBLIC_ é obrigatório pro Next.js expor no client.
# Vão em web/.env.local (Vercel env em produção).
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL do backend FastAPI no Fly.io (ex.: https://delta-ai-api.fly.dev)
NEXT_PUBLIC_API_URL=

# App ID do OneSignal (público, usado pelo SDK web de push)
NEXT_PUBLIC_ONESIGNAL_APP_ID=

# ------------------------------------------------------------
# Google OAuth (provider do Supabase Auth)
# Config principal fica no painel do Supabase (Authentication >
# Providers > Google). Mantido aqui pra paridade com ambiente local
# e scripts que precisem validar client id/secret.
# ------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ------------------------------------------------------------
# Grok (xAI) — IA do chat. NUNCA chamado direto de um módulo, sempre
# via app/ai/grok_client.py (wrapper com anonimização obrigatória).
# ------------------------------------------------------------
GROK_API_KEY=
GROK_API_BASE_URL=https://api.x.ai/v1

# ------------------------------------------------------------
# Resend — email transacional (free tier: 3k/mês, 100/dia)
# ------------------------------------------------------------
RESEND_API_KEY=

# ------------------------------------------------------------
# OneSignal — push notifications (free tier: até 10k dispositivos)
# ------------------------------------------------------------
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# ------------------------------------------------------------
# Sentry — monitoramento de erros (free tier: 5k erros/mês).
# DSNs separados por app — nunca compartilhe o mesmo DSN entre
# backend e frontend.
# ------------------------------------------------------------
SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=
